# Lamma — environment variables
# Copy this file to `.env` and adjust as needed.

# Prisma database URL (local dev uses SQLite).
# In production, switch to PostgreSQL:
#   DATABASE_URL="postgresql://user:pass@host:5432/lamma?schema=public"
DATABASE_URL="file:./db/custom.db"

# z-ai-web-dev-sdk — AI skills (LLM, image generation) used by the
# concierge, letter summaries, and description enhancer. Required for
# AI features to return real content; otherwise they fall back to
# deterministic mock content.
ZAI_API_KEY=""

# NextAuth.js — used only if authentication is wired to a real provider.
# The demo uses a client-side mock auth store (no secret needed for dev).
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
